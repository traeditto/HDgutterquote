# Optional mapping and AI visualization services
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key

# Persistent contractor activity and server-enforced render credits
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
RENDER_INITIAL_CREDITS=20
RENDER_MAX_PER_IP_HOUR=12
ADMIN_LEAD_RETENTION_DAYS=30

# Stripe one-time rendering credit pack
STRIPE_SECRET_KEY=sk_test_or_live_key
STRIPE_RENDER_CREDIT_PRICE_ID=price_render_credit_pack
STRIPE_WEBHOOK_SECRET=whsec_template_billing_webhook_secret
RENDER_CREDITS_PER_PACK=100

# Used only when running one company site directly. Generated sites receive a unique key.
CONTRACTOR_TENANT_ID=traeditto/example-gutter-company
CONTRACTOR_ADMIN_KEY=replace-with-a-long-random-dashboard-key

# Optional lead delivery through Resend
RESEND_API_KEY=your_resend_api_key
LEAD_FROM=Gutter Quotes <leads@your-verified-domain.com>

# Optional Meta Conversions API. The public Pixel ID is entered in /setup.
META_CAPI_ACCESS_TOKEN=your_meta_capi_access_token
META_TEST_EVENT_CODE=

# Server-only GitHub credentials used after contractor approval.
# Mark GITHUB_TEMPLATE_REPO as a template repository in GitHub settings.
GITHUB_TOKEN=your_fine_grained_github_token
GITHUB_OWNER=your-github-account
GITHUB_TEMPLATE_REPO=your-github-account/HDgutterquote

# Server-only Vercel credentials used to deploy each generated repository
VERCEL_TOKEN=your_vercel_access_token
VERCEL_TEAM_ID=

# Legacy shared-repository deployment route (optional backwards compatibility)
VERCEL_TEMPLATE_REPO=your-github-account/gutterquote-template
VERCEL_TEMPLATE_BRANCH=main

# Private key entered by an authorized user before generating a repository
GUTTERQUOTE_DEPLOY_KEY=replace-with-a-long-random-value
